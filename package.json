{
  "name": "needmarket",
  "private": true,
  "version": "0.0.0",
  "description": "Telegram Mini App — маркетплейс блогеров и бизнеса (монорепо)",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace apps/api",
    "dev:miniapp": "npm run dev --workspace apps/miniapp",
    "build": "npm run build --workspaces --if-present",
    "build:server": "npm run build --workspace apps/api",
    "start:server": "npm run start --workspace apps/api",
    "typecheck:server": "npm run typecheck --workspace apps/api",
    "test": "npm run test --workspace apps/api",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "npm run db:migrate --workspace apps/api",
    "db:reset": "npm run db:reset --workspace apps/api",
    "db:generate": "npm run db:generate --workspace apps/api"
  },
  "engines": {
    "node": ">=20"
  }
}
