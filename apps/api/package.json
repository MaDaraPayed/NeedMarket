{
  "name": "@needmarket/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate",
    "start": "prisma migrate deploy && tsx src/server.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "db:deploy": "prisma migrate deploy",
    "test": "vitest run"
  },
  "dependencies": {
    "@needmarket/shared": "*",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.1.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tma.js/init-data-node": "^2.0.7",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "grammy": "^1.44.0",
    "prisma": "^7.8.0",
    "tsx": "^4.22.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
