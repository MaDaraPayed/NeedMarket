# NeedMarket — Backend (apps/api)
# Переменные читаются из .env в КОРНЕ монорепо.
# В Railway задавать в Variables → Service (не через файл).

# Токен бота из @BotFather в Telegram.
BOT_TOKEN=123456:ABC-DEF...

# HTTPS-URL фронтенда (Vercel/туннель). Бот показывает его в Menu Button.
MINI_APP_URL=https://your-app.vercel.app

# PostgreSQL connection string. Railway подставит автоматически при Attach Database.
DATABASE_URL=postgresql://user:pass@host:5432/needmarket?schema=public

# Тестовая БД (только для npm test). Не нужна на Railway.
TEST_DATABASE_URL=postgresql://user:pass@host:5432/needmarket_test?schema=public

# Numeric id приватного канала-хранилища медиа. Необязателен.
MEDIA_CHANNEL_ID=-1001234567890

# Секрет для подписи JWT (openssl rand -hex 32).
JWT_SECRET=<случайная-строка-32+-символов>

# Порт. Railway подставит $PORT автоматически; дефолт в коде — 3000.
PORT=3000

# Разрешённые origin(ы) для CORS (список через запятую). В проде — URL Vercel-деплоя.
CORS_ORIGIN=https://your-app.vercel.app

# CSV telegram id администраторов: "123456,789012". Пусто = нет админов.
ADMIN_TELEGRAM_IDS=

# ── Webhook-режим бота ───────────────────────────────────────
# Базовый HTTPS-URL этого API (публичный адрес Railway) без trailing slash.
# Telegram будет слать обновления на ${WEBHOOK_URL}/telegram/webhook.
# Если не задан — бот использует long polling.
WEBHOOK_URL=https://your-api.up.railway.app

# Случайная строка для верификации webhook-запросов (openssl rand -hex 16).
WEBHOOK_SECRET=<случайная-строка>
