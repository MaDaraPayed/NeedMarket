# NeedMarket — Frontend (apps/miniapp)
# VITE_* переменные читаются из .env в КОРНЕ монорепо (envDir в vite.config.ts).
# В Vercel задавать в Settings → Environment Variables.

# Абсолютный HTTPS-URL бэкенда (Railway).
# В ДЕВЕ оставь ПУСТЫМ — запросы проксируются Vite (см. vite.config.ts).
VITE_API_URL=https://your-api.up.railway.app
