# ─────────────────────────────────────────────────────────────
# NeedMarket — единый .env для монорепо (скопируй в .env в корне)
# apps/api читает этот файл из корня; apps/miniapp берёт отсюда VITE_*.
# ─────────────────────────────────────────────────────────────

# ══════════════════ Backend (apps/api) ══════════════════

# Токен бота из BotFather. ЖИВЁТ ТОЛЬКО НА БЭКЕНДЕ, никогда не на фронте.
BOT_TOKEN=123456:ABC-DEF...

# HTTPS-URL фронтенда (Mini App), куда ведёт кнопка бота и Menu Button.
# В деве — адрес туннеля (cloudflared/ngrok) на Vite-фронт.
MINI_APP_URL=https://your-frontend-tunnel.example.com

# Строка подключения к PostgreSQL.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/needmarket?schema=public

# Отдельная БД для интеграционных тестов (npm test). По умолчанию DATABASE_URL.
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/needmarket_test?schema=public

# Numeric id приватного канала-хранилища медиа (логотипы и т.п.). Бот — админ в нём.
# Как получить: добавь бота админом, опубликуй пост — в логах появится "channel_post id=...".
# Необязателен: без него загрузка/раздача лого вернёт 503.
MEDIA_CHANNEL_ID=-1001234567890

# Секрет для подписи НАШИХ JWT (любая длинная случайная строка).
JWT_SECRET=change-me-to-a-long-random-string

# Порт API (Railway подставит свой PORT автоматически; дефолт 3000).
PORT=3000

# Разрешённые origin(ы) для CORS. Поддерживает список через запятую.
# В ДЕВЕ оставь * (фронт ходит через Vite-proxy). В ПРОДЕ — URL фронта на Vercel.
# Пример: CORS_ORIGIN=https://your-app.vercel.app,https://needmarket.example.com
CORS_ORIGIN=*

# CSV telegram id администраторов платформы: "123456,789012". Пусто = нет админов.
ADMIN_TELEGRAM_IDS=

# ── Webhook-режим бота (только для прода на Railway) ──────────────────────────
# Если задан WEBHOOK_URL — бот работает через webhook; иначе — long polling (дев).
# WEBHOOK_URL — базовый HTTPS-URL API БЕЗ trailing slash (например: https://my-api.up.railway.app)
# Telegram будет слать обновления на ${WEBHOOK_URL}/telegram/webhook.
WEBHOOK_URL=
# Секретная строка для верификации входящих запросов от Telegram.
# Задай любую случайную строку, если используешь webhook. Берётся из Railway Variables.
WEBHOOK_SECRET=

# ══════════════════ Frontend (apps/miniapp) ══════════════════

# Абсолютный HTTPS-URL бэкенда (Railway). В ДЕВЕ ОСТАВЬ ПУСТЫМ —
# запросы идут относительно origin через Vite dev-proxy.
VITE_API_URL=
